{
  "name": "shopping-cart-api",
  "version": "1.0.0",
  "description": "A shopping cart API using Express, PostgreSQL and Sequelize",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node seed.js",
    "test": "newman run Shopping-Cart-API.postman_collection.json",
    "test:verbose": "newman run Shopping-Cart-API.postman_collection.json --reporters cli,json --reporter-json-export testResults.json"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.0"
  },
  "devDependencies": {
    "newman": "^6.2.1",
    "nodemon": "^3.0.1"
  }
}
