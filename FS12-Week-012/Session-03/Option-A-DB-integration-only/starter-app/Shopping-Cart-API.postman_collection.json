					"name": "Add to Cart",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Cart item created with correct data', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res).to.have.property('id');",
									"    pm.expect(res.quantity).to.eql(2);",
									"});",
									"",
									"pm.test('User and Product are included', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res).to.have.property('User');",
									"    pm.expect(res).to.have.property('Product');",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('cart_item_id', pm.response.json().id);",
									"}"
