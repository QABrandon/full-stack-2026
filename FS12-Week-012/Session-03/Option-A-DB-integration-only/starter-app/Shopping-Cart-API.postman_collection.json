				{
					"name": "Create User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test('Status code is 201', function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test('Response contains user data', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res).to.have.property('id');",
									"    pm.expect(res).to.have.property('name');",
									"    pm.expect(res).to.have.property('email');",
									"    pm.expect(res).to.have.property('createdAt');",
									"});",
									"",
									"pm.test('Email is converted to lowercase', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res.email).to.match(/^[a-z0-9@._-]+$/);",
									"});",
									"",
									"pm.test('Name matches request data', function () {",
									"    const res = pm.response.json();",
									"    pm.expect(res.name).to.eql('John Doe');",
									"});",
									"",
									"if (pm.response.code === 201) {",
									"    pm.collectionVariables.set('user_id', pm.response.json().id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
