# PostgreSQL Connection (Option A: individual settings for local)
DB_NAME=music_favorites_db
# Mac (Homebrew): your macOS username (run "whoami" in terminal to check)
# Windows: postgres
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# PostgreSQL Connection (Option B: connection string for Supabase)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# No API key needed — iTunes Search API requires no authentication!

PORT=3000
