{
  "info": {
    "name": "Blog API - Role-Based Authorization Demo",
    "description": "Walks through the role-based authorization flow: log in as the seeded admin and author, see what each role can and cannot do, and watch the requireRole middleware block forbidden actions.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "authorToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "authorUserId",
      "value": "2",
      "type": "string"
    },
    {
      "key": "authorPostId",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminPostId",
      "value": "1",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Public (no token needed)",
      "item": [
        {
          "name": "Get All Roles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returns admin and author roles\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.roles.map(r => r.name)).to.include.members(['admin', 'author']);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/roles",
              "host": ["{{baseUrl}}"],
              "path": ["roles"]
            },
            "description": "Lists every role and its permissions. Public so the UI and tutorials can show students what each role can do."
          },
          "response": []
        },
        {
          "name": "Get All Posts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has posts array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('posts');",
                  "    pm.expect(jsonData.posts).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Reading posts is open to anyone. The seed step creates two starter posts so this is never empty."
          },
          "response": []
        },
        {
          "name": "Get Single Post",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200 or 404\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 404]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{adminPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{adminPostId}}"]
            },
            "description": "Fetch one post by id. Public - no auth needed."
          },
          "response": []
        },
        {
          "name": "List Users WITHOUT Token (should fail)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Error message returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('token required');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "GET /users used to be public in the auth-only example. Now it is admin-only, so calling it without a token returns 401 (authentication failure)."
          },
          "response": []
        }
      ],
      "description": "Endpoints anyone can call without logging in."
    },
    {
      "name": "2. Login as Seeded Users",
      "item": [
        {
          "name": "Login as Admin (seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token contains admin role\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('admin');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"adminToken\", jsonData.token);",
                  "    console.log(\"Admin token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Log in using the seeded admin account. Saves the JWT to the {{adminToken}} variable so later requests can reuse it."
          },
          "response": []
        },
        {
          "name": "Login as Alice (seeded author)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Token contains author role\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('author');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authorToken\", jsonData.token);",
                  "    pm.collectionVariables.set(\"authorUserId\", jsonData.user.id);",
                  "    console.log(\"Author token saved for user id:\", jsonData.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"alice123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Log in using the seeded alice account (role: author). Saves the JWT to the {{authorToken}} variable and her id to {{authorUserId}}."
          },
          "response": []
        },
        {
          "name": "Register New User (defaults to author)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Newly registered user has author role\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('author');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"charlie\",\n  \"email\": \"charlie@example.com\",\n  \"password\": \"charlie123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "description": "New registrations are always given the author role. Admin must be granted by another admin via PATCH /users/:userId/role."
          },
          "response": []
        }
      ],
      "description": "Sign in to grab tokens for the rest of the journey."
    },
    {
      "name": "3. Author Journey (Alice)",
      "item": [
        {
          "name": "Get Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Profile shows author role and permissions\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('author');",
                  "    pm.expect(jsonData.user.permissions).to.include('post:create');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/profile",
              "host": ["{{baseUrl}}"],
              "path": ["profile"]
            },
            "description": "Profile now includes the role name, role description, and the full list of permissions for that role."
          },
          "response": []
        },
        {
          "name": "Create Post (as author)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authorPostId\", jsonData.post.id);",
                  "    console.log(\"Author post id saved:\", jsonData.post.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Alice's Post\",\n  \"content\": \"Authors can create posts. The role check passes through requireRole('admin','author').\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Author role passes the requireRole('admin','author') check, so creation is allowed."
          },
          "response": []
        },
        {
          "name": "Update Own Post (as author)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Title was updated\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.post.title).to.include('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Alice's Updated Post\",\n  \"content\": \"Authors can edit their own posts.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{authorPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{authorPostId}}"]
            },
            "description": "Author can update their OWN post. Both the role check and the ownership check pass."
          },
          "response": []
        },
        {
          "name": "Get My Posts (as author)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Returns posts array\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.posts).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/my-posts",
              "host": ["{{baseUrl}}"],
              "path": ["my-posts"]
            },
            "description": "Any authenticated user can see their own posts (no role restriction)."
          },
          "response": []
        },
        {
          "name": "Author Tries to List Users (should fail 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 403\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test(\"Error explains required role\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('admin');",
                  "    pm.expect(jsonData.yourRole).to.eql('author');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "Authentication passes (valid token) but authorization fails - the requireRole('admin') middleware returns 403 and tells the caller which role they actually have."
          },
          "response": []
        },
        {
          "name": "Author Tries to Update Admin's Post (should fail 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 403\", function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test(\"Ownership error message\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('your own posts');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{authorToken}}", "type": "string" }
              ]
            },
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Hijacked!\",\n  \"content\": \"This should not be allowed.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts/{{adminPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{adminPostId}}"]
            },
            "description": "Author has the right role to call PUT /posts but does not OWN this specific post. The controller's ownership check denies the request."
          },
          "response": []
        }
      ],
      "description": "Things Alice (an author) can and cannot do."
    },
    {
      "name": "4. Admin Journey",
      "item": [
        {
          "name": "List All Users (admin only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Each user has a role name\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.users[0]).to.have.property('roleName');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
            },
            "description": "With an admin token the same /users endpoint returns the user list including each user's role name."
          },
          "response": []
        },
        {
          "name": "Promote Alice to Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Alice is now admin\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('admin');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{authorUserId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{authorUserId}}", "role"]
            },
            "description": "Admin promotes Alice. Note: Alice's existing token still says 'author' until she logs in again, because role data is baked into the JWT at login time."
          },
          "response": []
        },
        {
          "name": "Re-Login as Alice (token refresh)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"New token reflects new admin role\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.user.roleName).to.eql('admin');",
                  "});",
                  "",
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"authorToken\", jsonData.token);",
                  "    console.log(\"Alice's token refreshed - she is now admin\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"password\": \"alice123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Roles are baked into JWTs at login time, so the previous {{authorToken}} still says 'author' even though Alice was just promoted. Logging back in mints a fresh token with the new role. Try it: stash the old token and re-run any author-only test - it will still 403."
          },
          "response": []
        },
        {
          "name": "Admin Deletes Alice's Post (any-post power)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Delete succeeded\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.include('deleted');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/posts/{{authorPostId}}",
              "host": ["{{baseUrl}}"],
              "path": ["posts", "{{authorPostId}}"]
            },
            "description": "The admin did not author this post but the controller skips the ownership check when isAdmin is true. This is the headline admin power."
          },
          "response": []
        },
        {
          "name": "Admin Tries to Demote Self (should fail 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Self-demote is blocked\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('your own admin role');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"author\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/1/role",
              "host": ["{{baseUrl}}"],
              "path": ["users", "1", "role"]
            },
            "description": "userController.updateUserRole has a guard that prevents an admin from demoting themselves so the system never ends up with zero admins by accident."
          },
          "response": []
        }
      ],
      "description": "Things only the admin can do."
    },
    {
      "name": "5. Error Scenarios",
      "item": [
        {
          "name": "Create Post Without Token (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Authentication error returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('token required');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Should fail\",\n  \"content\": \"No auth header.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/posts",
              "host": ["{{baseUrl}}"],
              "path": ["posts"]
            },
            "description": "Authentication middleware blocks the request before any role check runs."
          },
          "response": []
        },
        {
          "name": "Login With Wrong Password (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 401\", function () {",
                  "    pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test(\"Generic error to avoid username enumeration\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.eql('Invalid credentials');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": ["{{baseUrl}}"],
              "path": ["login"]
            },
            "description": "Wrong password returns the same generic error as a missing user, to avoid leaking which usernames exist."
          },
          "response": []
        },
        {
          "name": "Register Duplicate Username (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Duplicate error returned\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('already exists');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"alice\",\n  \"email\": \"alice2@example.com\",\n  \"password\": \"alice123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/register",
              "host": ["{{baseUrl}}"],
              "path": ["register"]
            },
            "description": "Alice is seeded on startup so registering her again must fail with 400."
          },
          "response": []
        },
        {
          "name": "Promote With Invalid Role Name (400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 400\", function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test(\"Lists valid role names\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.error).to.include('Valid roles are');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{adminToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleName\": \"superuser\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{authorUserId}}/role",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{authorUserId}}", "role"]
            },
            "description": "Trying to assign a role that does not exist gives a clear 400 with the list of valid role names."
          },
          "response": []
        }
      ],
      "description": "Common failure cases. Useful to confirm error messages stay friendly."
    }
  ]
}
